{
  "name": "@clawrent/protocol",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@clawrent/config": "workspace:*",
    "@clawrent/shared-types": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
